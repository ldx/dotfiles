#!/usr/bin/env bash
# Waybar status script for agent-deck.
# Outputs JSON: icon + CSS class based on running/waiting/idle state.

ICON=$'\uf085'  # nf-fa-cogs (U+F085)

status=$("$HOME/.local/bin/agent-deck" status 2>/dev/null | head -1)

if [[ -z "$status" ]]; then
    /usr/bin/jq -cn --arg text "$ICON" --arg class "idle" --arg tooltip "agent-deck unavailable" \
        '{text: $text, class: $class, tooltip: $tooltip}'
    exit 0
fi

running=$(echo "$status" | grep -oP '\d+(?= running)' || echo 0)
waiting=$(echo "$status" | grep -oP '\d+(?= waiting)' || echo 0)

if [[ "$running" -gt 0 ]]; then
    class="running"
elif [[ "$waiting" -gt 0 ]]; then
    class="waiting"
else
    class="idle"
fi

/usr/bin/jq -cn --arg text "$ICON" --arg class "$class" --arg tooltip "$status" \
    '{text: $text, class: $class, tooltip: $tooltip}'
