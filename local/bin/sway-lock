#!/bin/sh

lock_1password_if_present() {
    wait_for_lock="${1:-no}"

    command -v 1password >/dev/null 2>&1 || return 0

    # Do not start 1Password just to lock it. If it is not already running,
    # `1password --lock` launches the desktop app and can block swaylock.
    pgrep -x 1password >/dev/null 2>&1 || pgrep -f '/opt/1Password/1password' >/dev/null 2>&1 || return 0

    if command -v timeout >/dev/null 2>&1; then
        lock_cmd="timeout 2s 1password --lock"
    else
        lock_cmd="1password --lock"
    fi

    if [ "$wait_for_lock" = yes ]; then
        sh -c "$lock_cmd" >/dev/null 2>&1 || true
    else
        sh -c "$lock_cmd" >/dev/null 2>&1 &
    fi
}

case "${1:-}" in
    --1password-only)
        lock_1password_if_present yes
        exit 0
        ;;
esac

lock_1password_if_present no
exec swaylock -f "$@"
