#!/bin/sh
# Compositor-aware screen locker.
# - Locks 1Password if it is already running.
# - Uses hyprlock in Hyprland, swaylock elsewhere.

lock_1password_if_present() {
    wait_for_lock="${1:-no}"

    command -v 1password >/dev/null 2>&1 || return 0

    # Do not start 1Password just to lock it.
    pgrep -x 1password >/dev/null 2>&1 || pgrep -f '^/opt/1Password/1password' >/dev/null 2>&1 || return 0

    if command -v timeout >/dev/null 2>&1; then
        lock_cmd="timeout 2s 1password --lock"
    else
        lock_cmd="1password --lock"
    fi

    if [ "$wait_for_lock" = yes ]; then
        sh -c "$lock_cmd" >/dev/null 2>&1 || true
    else
        sh -c "$lock_cmd" >/dev/null 2>&1 &
    fi
}

case "${1:-}" in
    --1password-only)
        lock_1password_if_present yes
        exit 0
        ;;
esac

lock_1password_if_present no

if [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ] && command -v hyprlock >/dev/null 2>&1; then
    pidof hyprlock >/dev/null 2>&1 || exec hyprlock "$@"
    exit 0
fi

if command -v swaylock >/dev/null 2>&1; then
    exec swaylock -f "$@"
fi

echo "screen-lock: no supported locker found" >&2
exit 1
