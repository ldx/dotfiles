[{
    "layer": "top",
    "position": "top",
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-right": ["idle_inhibitor", "battery", "cpu", "temperature", "memory", "disk", "pulseaudio", "backlight", "network", "tray", "custom/agentdeck", "custom/notification", "clock"],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true
    },

    "hyprland/window": {
        "max-length": 50
    },

    "tray": {
        "spacing": 8
    },

    "custom/agentdeck": {
        "exec": "~/.local/bin/agentdeck-status",
        "interval": 5,
        "return-type": "json",
        "on-click": "~/.local/bin/agentdeck-toggle",
        "signal": 8,
        "tooltip": true
    },

    "custom/notification": {
        "tooltip": true,
        "format": "{text}",
        "return-type": "json",
        "exec-if": "command -v makoctl >/dev/null",
        "exec": "~/.local/bin/mako-notification-status",
        "on-click": "~/.local/bin/mako-notification-toggle",
        "on-click-right": "makoctl dismiss --all; pkill -RTMIN+9 waybar",
        "on-click-middle": "makoctl restore; pkill -RTMIN+9 waybar",
        "signal": 9,
        "escape": true
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "Inhibit: on",
            "deactivated": "Inhibit: off"
        }
    },

    "battery": {
        "format": "Batt: {capacity}%",
        "format-charging": "Batt: {capacity}% ↑",
        "format-full": "Batt: Full",
        "states": { "warning": 30, "critical": 10 }
    },

    "cpu": {
        "format": "CPU: {usage}%",
        "interval": 1
    },

    "temperature": {
        "format": "Temp: {temperatureC}°C",
        "critical-threshold": 80,
        "interval": 5
    },

    "memory": {
        "format": "Mem: {percentage}%"
    },

    "disk": {
        "format": "Disk: {percentage_used}%",
        "path": "/"
    },

    "pulseaudio": {
        "format": "Vol: {volume}%",
        "format-muted": "Vol: muted",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },

    "backlight": {
        "format": "Bright: {percent}%"
    },

    "network": {
        "format-wifi": "{ifname}: ↓{bandwidthDownBytes} ↑{bandwidthUpBytes}",
        "format-ethernet": "{ifname}: ↓{bandwidthDownBytes} ↑{bandwidthUpBytes}",
        "format-disconnected": "disconnected",
        "interval": 2
    },

    "clock": {
        "format": "{:%b %e %a %Y %H:%M}"
    }
}]
